# Optional WebRTC NAT traversal settings for transfers outside the same network.
# Vite exposes VITE_* values to the browser bundle, so do not put long-lived
# private TURN credentials here unless you are comfortable shipping them to users.

# Optional public app URL used when a sender is running Void on localhost or a
# private Wi-Fi address but needs to share a link with a phone on cellular data.
# Defaults to this repo's GitHub Pages URL.
# VITE_PUBLIC_APP_URL=https://extremq8.github.io/Void/

# Void includes a public TURN fallback for cross-network testing. Set this only
# if you want to disable that fallback and provide your own TURN servers.
# VITE_DISABLE_PUBLIC_TURN=true

# Comma- or space-separated STUN URLs.
VITE_STUN_URLS=stun:stun.l.google.com:19302

# Comma- or space-separated TURN URLs. Include UDP plus TCP/TLS fallbacks.
# Example:
# VITE_TURN_URLS=turn:turn.example.com:3478?transport=udp,turn:turn.example.com:3478?transport=tcp,turns:turn.example.com:5349?transport=tcp
# VITE_TURN_USERNAME=void
# VITE_TURN_CREDENTIAL=replace-with-your-turn-password

# Optional full RTCIceServer JSON. This is appended after the PeerJS defaults.
# VITE_ICE_SERVERS=[{"urls":["turns:turn.example.com:5349?transport=tcp"],"username":"void","credential":"replace-with-your-turn-password"}]

# Use "relay" only when you want to force all traffic through TURN for testing
# or for locked-down networks. Leave unset for normal direct-first behavior.
# VITE_ICE_TRANSPORT_POLICY=relay

# Optional candidate gathering hint.
# VITE_ICE_CANDIDATE_POOL_SIZE=4
